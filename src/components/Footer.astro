---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-grid">
      <div>
        <div class="footer-brand"><Logo size="md" showTagline /></div>
        <p class="footer-desc">The enterprise AI platform that runs your hiring today and designs your workforce for tomorrow.</p>
      </div>
      <div class="footer-col">
        <h5>Platform</h5>
        <a href="#">AI Hiring Co-pilot</a>
        <a href="#">AI Talent Intelligence</a>
        <a href="#">AI Interviews</a>
        <a href="#">Workforce Design</a>
        <a href="#pricing">Pricing</a>
        <a href="#">Integrations</a>
      </div>
      <div class="footer-col">
        <h5>Resources</h5>
        <a href="#">Documentation</a>
        <a href="#">Blog</a>
        <a href="#">Case Studies</a>
        <a href="#">Hiring Guide</a>
        <a href="#">API</a>
      </div>
      <div class="footer-col">
        <h5>Company</h5>
        <a href="#">About</a>
        <a href="#">Careers</a>
        <a href="#">Contact</a>
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; {year} Klaras, Inc. All rights reserved.</span>
      <span>Det klaras. It's handled.</span>
    </div>
  </div>
</footer>

<style>
  footer { border-top: 1px solid var(--border); background: var(--bg-primary); padding: 64px 0 40px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px; }
  .footer-brand { font-family: 'Space Grotesk', sans-serif; font-size: 1.4rem; font-weight: 700; margin-bottom: 12px; }
  .footer-brand span { color: var(--accent-1); }
  .footer-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.6; max-width: 300px; }
  .footer-col h5 { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-secondary); margin-bottom: 16px; font-weight: 600; }
  .footer-col a { display: block; font-size: 0.85rem; color: var(--text-muted); text-decoration: none; padding: 4px 0; transition: color 0.2s; }
  .footer-col a:hover { color: var(--text-primary); }
  .footer-bottom { display: flex; justify-content: space-between; align-items: center; padding-top: 32px; border-top: 1px solid var(--border); font-size: 0.8rem; color: var(--text-muted); }
</style>
